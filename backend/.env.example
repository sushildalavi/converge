# ── core ─────────────────────────────────────────────
DATABASE_URL=postgresql://replayforge:replayforge@postgres:5432/replayforge
REDIS_URL=redis://redis:6379/0

# ── worker ───────────────────────────────────────────
# Leave WORKER_NAME blank to auto-derive from container hostname (enables horizontal scaling).
WORKER_NAME=
MAX_ATTEMPTS=4

# ── AI (optional, leave blank for free template summaries) ──
ANTHROPIC_API_KEY=

# ── observability ────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
ENVIRONMENT=development

# ── http ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── security ─────────────────────────────────────────
# Comma-separated list of allowed API keys for write endpoints
# (empty in dev = unauthenticated; required in production)
API_KEYS=
RATE_LIMIT_WRITE_PER_MIN=60
RATE_LIMIT_READ_PER_MIN=600
MAX_REQUEST_BODY_BYTES=262144

# ── db pool ──────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=300
