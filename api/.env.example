# ── core ─────────────────────────────────────────────
# Point DATABASE_URL at a managed Postgres instance such as Supabase in production.
DATABASE_URL=postgresql://replayforge:replayforge@127.0.0.1:15432/replayforge
REDIS_URL=redis://127.0.0.1:16379/0

# ── worker ───────────────────────────────────────────
# Leave WORKER_NAME blank to auto-derive from container hostname (enables horizontal scaling).
WORKER_NAME=
MAX_ATTEMPTS=4

# ── AI (optional, free/local defaults) ──
AI_PROVIDER=disabled
JUDGE_PROVIDER=auto
OPENAI_JUDGE_MODEL=gpt-4o-mini
GEMINI_JUDGE_MODEL=gemini-1.5-flash
OLLAMA_BASE_URL=http://localhost:11434
AI_MODEL=llama3.1:8b
AI_FALLBACK_MODEL=qwen2.5-coder:7b
AI_TIMEOUT_SECONDS=20
ANTHROPIC_API_KEY=

# ── observability ────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
ENVIRONMENT=development

# ── http ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5171
EVENT_BACKEND=redis
FORGELOG_URL=http://forgelog:9090

# ── security ─────────────────────────────────────────
# Comma-separated list of allowed API keys for write endpoints
# (empty in dev = unauthenticated; required in production)
API_KEYS=
RATE_LIMIT_WRITE_PER_MIN=60
RATE_LIMIT_READ_PER_MIN=600
MAX_REQUEST_BODY_BYTES=262144

# ── db pool ──────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=300
